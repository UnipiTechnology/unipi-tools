#ifndef UNIPICHANNEL_VERSION_H
#define UNIPICHANNEL_VERSION_H

/* The major version, (1, if %LIBUNIPICHANNEL_VERSION is 1.2.3) */
#define LIBUNIPICHANNEL_VERSION_MAJOR (@LIBUNIPICHANNEL_VERSION_MAJOR@)

/* The minor version (2, if %LIBUNIPICHANNEL_VERSION is 1.2.3) */
#define LIBUNIPICHANNEL_VERSION_MINOR (@LIBUNIPICHANNEL_VERSION_MINOR@)

/* The micro version (3, if %LIBUNIPICHANNEL_VERSION is 1.2.3) */
#define LIBUNIPICHANNEL_VERSION_MICRO (@LIBUNIPICHANNEL_VERSION_MICRO@)

/* The full version, like 1.2.3 */
#define LIBUNIPICHANNEL_VERSION @LIBUNIPICHANNEL_VERSION@

/* The full version, in string form (suited for string concatenation)
 */
#define LIBUNIPICHANNEL_VERSION_STRING "@LIBUNIPICHANNEL_VERSION@"

/* Numerically encoded version, eg. v1.2.3 is 0x010203 */
#define LIBUNIPICHANNEL_VERSION_HEX                                                                      \
    ((LIBUNIPICHANNEL_VERSION_MAJOR << 16) | (LIBUNIPICHANNEL_VERSION_MINOR << 8) |                            \
     (LIBUNIPICHANNEL_VERSION_MICRO << 0))

/* Evaluates to True if the version is greater than @major, @minor and @micro
 */
#define LIBUNIPICHANNEL_VERSION_CHECK(major, minor, micro)                                               \
    (LIBUNIPICHANNEL_VERSION_MAJOR > (major) ||                                                          \
     (LIBUNIPICHANNEL_VERSION_MAJOR == (major) && LIBUNIPICHANNEL_VERSION_MINOR > (minor)) ||                  \
     (LIBUNIPICHANNEL_VERSION_MAJOR == (major) && LIBUNIPICHANNEL_VERSION_MINOR == (minor) &&                  \
      LIBUNIPICHANNEL_VERSION_MICRO >= (micro)))

#endif /* UNIPICHANNEL_VERSION_H */
