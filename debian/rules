#!/usr/bin/make -f
# See debhelper(7) (uncomment to enable)
# output every command that modifies files on the build system.
#export DH_VERBOSE = 1


# see FEATURE AREAS in dpkg-buildflags(1)
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# see ENVIRONMENT in dpkg-buildflags(1)
# package maintainers to append CFLAGS
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
# package maintainers to append LDFLAGS
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed


PROJECT_VERSION=$(shell dpkg-parsechangelog -S Version)

clean:
	rm -f debian/*.service
	dh clean

%:
	dh $@ --with autoreconf --exclude=.la

override_dh_auto_configure:
	dh_auto_configure -- \
	    --libdir=/usr/lib/$(DEB_HOST_MULTIARCH) \
	    --sysconfdir=/etc \
	    --bindir=/opt/unipi/tools \
	    --sbindir=/opt/unipi/tools \
	    --disable-silent-rules

override_dh_autoreconf:
	./autogen.sh

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_build:
	dh_auto_build -- PROJECT_VERSION=$(PROJECT_VERSION)

override_dh_gencontrol:
	dh_gencontrol -- -Tdebian/substvars

override_dh_missing:
	dh_missing --fail-missing


override_dh_installsystemd:
	ln -s tmp/lib/systemd/system/unipifwupdate.service debian/unipi-firmware-tools.unipifwupdate.service
	ln -s tmp/lib/systemd/system/unipitcp.service debian/unipi-modbus-tools.unipitcp.service
	dh_installsystemd --name=unipitcp
	dh_installsystemd --no-enable --no-start --name=unipifwupdate
